// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  tasks        Task[]
  systemLogs   SystemLog[]
  days         Day[]
  streaks      Streak?
  widgets      Widget[]
  goals        Goal[]
  habits       Habit[]
  eventLogs    EventLog[]
  chatMessages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  text      String
  role      String   // "USER" | "MODEL"
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Task {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  period    String   // "day" | "week" | "month"
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  dayId     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       Day?     @relation(fields: [dayId], references: [id], onDelete: SetNull)
  parent    Task?    @relation("TaskChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Task[]   @relation("TaskChildren")
}

model Day {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  totalTasks     Int      @default(0)
  completedTasks Int      @default(0)
  completionPercentage Int  @default(0)
  status         String   @default("FAILED") // "COMPLETED" | "PARTIAL" | "FAILED"
  isCompleted    Boolean  @default(false)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@unique([userId, date])
}


model Habit {
  id            String   @id @default(cuid())
  title         String
  duration      Int      @default(15) // In minutes
  streak        Int      @default(0)
  lastCompleted DateTime?
  createdAt     DateTime @default(now())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id           String   @id @default(cuid())
  title        String
  type         String   // "money" | "task" | "habit"
  style        String   @default("CLASSIC") // New field for visualization
  targetValue  Float
  currentValue Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        String   @id @default(cuid())
  type      String   // "TASK_COMPLETED", "TASK_CREATED", etc.
  payload   Json?
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Streak {
  id      String @id @default(cuid())
  current Int    @default(0)
  best    Int    @default(0)
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Widget {
  id     String @id @default(cuid())
  type   String // "DAY_GOALS" | "NOTES"
  posX   Int    @default(0)
  posY   Int    @default(0)
  w      Int    @default(300)
  h      Int    @default(400)
  data   Json?
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id        String   @id @default(cuid())
  message   String
  level     String   @default("INFO") // "INFO" | "WARN" | "ERROR"
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
